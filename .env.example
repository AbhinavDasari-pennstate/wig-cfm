# Anthropic / Claude Agent SDK
ANTHROPIC_API_KEY=sk-ant-...

# SAP S/4HANA CRM (REST)
SAP_API_URL=https://your-sap-instance.com/api
SAP_API_KEY=

# SAP MM (Materials Management) — OData v4 / Workflow
SAP_MM_ODATA_URL=https://your-sap-instance.com/odata/v4
SAP_WORKFLOW_URL=https://your-sap-instance.com/workflow

# Courier (DHL / Aramex / SAP GTT)
COURIER_API_URL=https://your-courier-api.com
COURIER_API_KEY=

# Channels
EMAIL_SMTP_HOST=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
WHATSAPP_TOKEN=

# Demo backend selector: "memory" (default, offline) or "http" (real SAP)
WIG_BACKEND=memory
